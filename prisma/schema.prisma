generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum BlogStatus {
  draft
  pending_review
  approved
  published
  rejected
}

enum TicketStatus {
  open
  sold
}

enum ChatReportStatus {
  open
  actioned
  dismissed
}

enum PredictionPurchaseStatus {
  pending
  approved
  rejected
}

model Admin {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String     @unique
  password      String
  approvedBlogs BlogPost[] @relation("ApprovedBlogs")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Category {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String     @unique
  slug      String     @unique
  posts     BlogPost[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model BlogPost {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  slug            String     @unique
  categoryId      String     @db.ObjectId
  category        Category   @relation(fields: [categoryId], references: [id])
  summary         String
  outline         String
  content         String
  featureImage    String?
  tags            String
  metaTitle       String
  metaDescription String
  status          BlogStatus @default(draft)
  generatedByAI   Boolean    @default(false)
  approvedById    String?    @db.ObjectId
  approvedBy      Admin?     @relation("ApprovedBlogs", fields: [approvedById], references: [id])
  authorName      String     @default("Sports AI Desk")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  publishedAt     DateTime?
}

model SiteContent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  title       String
  description String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FanUser {
  id                  String               @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  email               String               @unique
  phone               String?
  tickets             MatchTicket[]
  bids                TicketBid[]          @relation("BidderBids")
  rewards             TicketBid[]          @relation("RewardedBids")
  predictionPurchases PredictionPurchase[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model MatchTicket {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  sellerId         String       @db.ObjectId
  seller           FanUser      @relation(fields: [sellerId], references: [id])
  matchTitle       String
  venue            String
  matchDate        DateTime
  seatDetails      String
  basePrice        Float
  description      String
  status           TicketStatus @default(open)
  soldBidId        String?      @db.ObjectId
  soldBid          TicketBid?   @relation("SoldBid", fields: [soldBidId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bids             TicketBid[]  @relation("TicketBids")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  soldAt           DateTime?
  sellerRewardNote String?
}

model TicketBid {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  ticketId     String        @db.ObjectId
  ticket       MatchTicket   @relation("TicketBids", fields: [ticketId], references: [id])
  bidderId     String        @db.ObjectId
  bidder       FanUser       @relation("BidderBids", fields: [bidderId], references: [id])
  amount       Float
  comment      String
  isWinningBid Boolean       @default(false)
  isRewarded   Boolean       @default(false)
  rewardedById String?       @db.ObjectId
  rewardedBy   FanUser?      @relation("RewardedBids", fields: [rewardedById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  soldTicket   MatchTicket[] @relation("SoldBid")
}

model ChatUser {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  phone       String        @unique
  isBlocked   Boolean       @default(false)
  blockReason String?
  messages    ChatMessage[]
  reportsMade ChatReport[]  @relation("ReporterReports")
  reportsOnMe ChatReport[]  @relation("ReportedUserReports")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ChatMessage {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  userId    String       @db.ObjectId
  user      ChatUser     @relation(fields: [userId], references: [id])
  text      String
  isDeleted Boolean      @default(false)
  reports   ChatReport[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ChatReport {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  messageId      String           @db.ObjectId
  message        ChatMessage      @relation(fields: [messageId], references: [id])
  reporterId     String           @db.ObjectId
  reporter       ChatUser         @relation("ReporterReports", fields: [reporterId], references: [id])
  reportedUserId String           @db.ObjectId
  reportedUser   ChatUser         @relation("ReportedUserReports", fields: [reportedUserId], references: [id])
  reason         String
  status         ChatReportStatus @default(open)
  adminNote      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([messageId, reporterId])
}

model ChatCleanupState {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  key           String    @unique
  lastCleanupAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PredictionMaster {
  id                String               @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  email             String               @unique
  phone             String
  upiId             String
  posts             PredictionPost[]
  purchaseApprovals PredictionPurchase[] @relation("ApproverPurchases")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model PredictionPost {
  id          String               @id @default(auto()) @map("_id") @db.ObjectId
  masterId    String               @db.ObjectId
  master      PredictionMaster     @relation(fields: [masterId], references: [id])
  matchTitle  String
  title       String
  content     String
  slipId      String
  fee         Float
  platform    String
  chanceToWin Int
  purchases   PredictionPurchase[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model PredictionPurchase {
  id          String                   @id @default(auto()) @map("_id") @db.ObjectId
  postId      String                   @db.ObjectId
  post        PredictionPost           @relation(fields: [postId], references: [id])
  buyerId     String                   @db.ObjectId
  buyer       FanUser                  @relation(fields: [buyerId], references: [id])
  masterId    String                   @db.ObjectId
  master      PredictionMaster         @relation("ApproverPurchases", fields: [masterId], references: [id])
  utr         String
  buyerPhone  String
  buyerEmail  String
  status      PredictionPurchaseStatus @default(pending)
  masterNote  String?
  requestedAt DateTime                 @default(now())
  approvedAt  DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@unique([postId, buyerId])
  @@index([masterId, status])
}
