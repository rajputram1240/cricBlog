generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum BlogStatus {
  draft
  pending_review
  approved
  published
  rejected
}

enum TicketStatus {
  open
  sold
}

model Admin {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String     @unique
  password      String
  approvedBlogs BlogPost[] @relation("ApprovedBlogs")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Category {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String     @unique
  slug      String     @unique
  posts     BlogPost[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model BlogPost {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  slug            String     @unique
  categoryId      String     @db.ObjectId
  category        Category   @relation(fields: [categoryId], references: [id])
  summary         String
  outline         String
  content         String
  featureImage    String?
  tags            String
  metaTitle       String
  metaDescription String
  status          BlogStatus @default(draft)
  generatedByAI   Boolean    @default(false)
  approvedById    String?    @db.ObjectId
  approvedBy      Admin?     @relation("ApprovedBlogs", fields: [approvedById], references: [id])
  authorName      String     @default("Sports AI Desk")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  publishedAt     DateTime?
}

model SiteContent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  title       String
  description String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FanUser {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String       @unique
  phone       String?
  tickets     MatchTicket[]
  bids        TicketBid[]  @relation("BidderBids")
  rewards     TicketBid[]  @relation("RewardedBids")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model MatchTicket {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  sellerId        String       @db.ObjectId
  seller          FanUser      @relation(fields: [sellerId], references: [id])
  matchTitle      String
  venue           String
  matchDate       DateTime
  seatDetails     String
  basePrice       Float
  description     String
  status          TicketStatus @default(open)
  soldBidId       String?      @db.ObjectId
  soldBid         TicketBid?   @relation("SoldBid", fields: [soldBidId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bids            TicketBid[]  @relation("TicketBids")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  soldAt          DateTime?
  sellerRewardNote String?
}

model TicketBid {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  ticketId      String      @db.ObjectId
  ticket        MatchTicket @relation("TicketBids", fields: [ticketId], references: [id])
  bidderId      String      @db.ObjectId
  bidder        FanUser     @relation("BidderBids", fields: [bidderId], references: [id])
  amount        Float
  comment       String
  isWinningBid  Boolean     @default(false)
  isRewarded    Boolean     @default(false)
  rewardedById  String?     @db.ObjectId
  rewardedBy    FanUser?    @relation("RewardedBids", fields: [rewardedById], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  soldTicket    MatchTicket[] @relation("SoldBid")
}
